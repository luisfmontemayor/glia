TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libcore.a
PKG_LIBS = -L$(LIBDIR) -Wl,--whole-archive -lcore -Wl,--no-whole-archive -lpthread -ldl -lm -lssl -lcrypto -lrt

$(SHLIB): $(STATLIB)

$(STATLIB):
	cd rust && cargo build --release --no-default-features --features r
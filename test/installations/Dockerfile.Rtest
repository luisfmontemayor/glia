# Use a minimal ubuntu image
FROM ubuntu:22.04

# Set environment variables for non-interactive installations
ENV DEBIAN_FRONTEND=noninteractive
ENV R_PROFILE_USER=/etc/R/Rprofile.site
ENV PATH="/root/.local/bin:${PATH}"

# Install system dependencies for building R packages and the rust core
RUN apt-get update && apt-get install -y \
    build-essential \
    gfortran \
    libreadline-dev \
    libpcre2-dev \
    liblzma-dev \
    libbz2-dev \
    zlib1g-dev \
    libuv1-dev \
    libgit2-dev \
    libsecret-1-dev \
    libxml2-dev \
    libfribidi-dev \
    libharfbuzz-dev \
    libfontconfig1-dev \
    libfreetype6-dev \
    pkg-config \
    rsync \
    libtiff-dev \
    libwebp-dev \
    libssl-dev \
    libcurl4-openssl-dev \
    curl \
    git \
    wget \
    ca-certificates \
    unzip \
    tzdata \
    libncurses5-dev \
    libncursesw5-dev \
    libjpeg-dev \
    libpng-dev \
    libx11-dev \
    libxt-dev \
    x11proto-core-dev \
    libice-dev \
    libsm-dev \
    libxext-dev \
    libxrender-dev \
    pandoc

# Copy the local repository content
WORKDIR /glia
COPY . /glia

# Remove pandoc from mise.toml and mise.lock to avoid GitHub API rate limits
RUN sed -i '/^pandoc = /d' mise.toml && \
    sed -i '/\[\[tools.pandoc\]\]/,/^[[:space:]]*$/d' mise.lock

# Install mise, and then use it to install project dependencies
ENV MISE_GITHUB_GITHUB_ATTESTATIONS=false
ENV MISE_PYTHON_GITHUB_ATTESTATIONS=false
ENV MISE_SETTINGS__GITHUB_ATTESTATIONS=false
ENV MISE_SETTINGS__VERIFY_SLSA=false
ENV MISE_SETTINGS__VERIFY=false
ENV R_CONFIGURE_OPTIONS="--with-x=no"
# Disable pak for renv to avoid "Subprocess is busy" errors in Docker
ENV RENV_CONFIG_PAK_ENABLED=FALSE
SHELL ["/bin/bash", "-c"]

RUN curl https://mise.run | sh && \
    chmod +x /root/.local/bin/mise && \
    mise trust && \
    mise plugin install r https://github.com/mise-plugins/mise-r.git && \
    mise install && \
    # Install renv globally to ensure setup tasks can run without .Rprofile failures
    mise exec -- Rscript -e "install.packages('renv', repos='https://cloud.r-project.org')" && \
    mise run setup:r-deps && \
    mise run gliar:build

# Final command to show that R is installed and gliar can be loaded
# We use mise run to ensure environment variables from .env.r are loaded
CMD ["mise", "exec", "--", "R", "-e", "library(gliar); print('gliar loaded successfully.')"]iar); print('gliar loaded successfully.')"]